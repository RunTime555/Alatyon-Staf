generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// User Model
model User {
  id               String      @id @default(cuid())
  mrn              String?     @unique 
  name             String
  email            String      @unique
  password         String
  role             String      @default("Patient") // Patient, Admin, LabTechnician
  
  // --- አዲስ የተጨመሩ የፕሮፋይል ክፍሎች ---
  phone            String?
  address          String?
  image            String?     @db.Text
  bloodGroup       String?
  emergencyContact String?
  emergencyPhone   String?
  occupation       String?
  dob              String?
  // ----------------------------------

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt 

  // Relationship
  labResults       LabResult[] @relation("PatientToResults")
}

// Lab Result Model
model LabResult {
  id             String   @id @default(cuid())
  testName       String   // e.g., CBC, Glucose, Malaria
  category       String   @default("General") // Added: e.g., Hematology, Chemistry
  testValue      String?  // Made optional because it's null while "Pending"
  unit           String?  // e.g., mg/dL, g/L
  status         String   @default("Pending") // Pending, Completed
  interpretation String?  @db.Text // AI or Doctor's note
  
  // Relationship
  patientId      String
  patient        User     @relation("PatientToResults", fields: [patientId], references: [id], onDelete: Cascade) // Added Cascade
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt // Added: Tracks when the result was actually entered
}